# === OMNIFY — Environment Variables ===
# Copy this to .env and fill in all required values before running.

# ─── MongoDB ─────────────────────────────────────────────────
# Required. Used by docker-compose to create the root user.
MONGO_USERNAME=admin
MONGO_PASSWORD=replace_with_a_strong_password

# ─── Backend ─────────────────────────────────────────────────
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Required in production. The public-facing URL of the backend (for CORS).
FRONTEND_URL=http://localhost:3000

# ─── Frontend (Next.js build-time) ───────────────────────────
# Required. The public-facing URL browsers use to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# ─── AI Service ──────────────────────────────────────────────
# Required for AI features (resume analysis, cover letter, career chat).
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Cloudinary (file uploads — avatars & resumes) ───────────
# Get yours at: https://cloudinary.com (free tier is sufficient)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (optional — required for password reset) ──────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Omnify <noreply@omnify.ai>
